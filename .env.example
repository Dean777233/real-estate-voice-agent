# Real Estate Voice Agent — copy to .env.local and fill in secrets.

# Nebius Token Factory (LLM / embeddings)
# https://console.nebius.com or Token Factory → API keys
NEBIUS_API_KEY=your_nebius_api_key_here

# Vapi voice agent — https://dashboard.vapi.ai → API Keys
# VAPI_API_KEY = private/server key (Bearer auth for server-side API calls)
VAPI_API_KEY=your_vapi_private_api_key_here
# VAPI_PUBLIC_KEY = public key (client-side web calls / SDK)
VAPI_PUBLIC_KEY=your_vapi_public_api_key_here
# VAPI_ASSISTANT_ID = DealScout assistant UUID from GET /assistant
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# InsForge (client-safe — exposed to browser)
NEXT_PUBLIC_INSFORGE_URL=https://zmyph3p8.us-east.insforge.app
# Run: npx @insforge/cli secrets get ANON_KEY
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# InsForge server-only (never commit; also in .insforge/project.json for CLI)
INSFORGE_API_KEY=your_insforge_api_key_here
